PORT=3002

# PostgreSQL para desarrollo local (npm run dev)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_NAME=ms_users

# JWT (mismo secret que MS-Auth)
JWT_SECRET=CHANGE_ME_JWT_SECRET

# Redis — cola de eventos hacia ms-auth (Bull)
REDIS_URL=redis://localhost:6379

# Cloudinary
CLOUDINARY_CLOUD_NAME=CHANGE_ME
CLOUDINARY_API_KEY=CHANGE_ME
CLOUDINARY_API_SECRET=CHANGE_ME

NODE_ENV=development

PORT=3002

# PostgreSQL — usado por la app
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_NAME=ms_users

# Broker — cola de eventos hacia ms-auth (Bull sobre Redis)
REDIS_BROKER_URL=redis://localhost:6379

# JWT — debe coincidir con ms-auth
JWT_SECRET=CHANGE_ME_JWT_SECRET

# ms-auth — URL y API key interna (deben coincidir con ms-auth)
MS_AUTH_URL=http://localhost:3001
INTERNAL_API_KEY=CHANGE_ME_INTERNAL_API_KEY

# Cloudinary — fotos de perfil
CLOUDINARY_CLOUD_NAME=CHANGE_ME
CLOUDINARY_API_KEY=CHANGE_ME
CLOUDINARY_API_SECRET=CHANGE_ME

# Gmail — envío de OTP para recuperar contraseña
GMAIL_USER=CHANGE_ME@gmail.com
GMAIL_APP_PASSWORD=CHANGE_ME

NODE_ENV=development
